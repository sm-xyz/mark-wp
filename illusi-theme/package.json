{
  "name": "illusi-theme",
  "version": "1.0.2",
  "description": "Ultra lightweight standalone WordPress theme with SPA-like feels",
  "scripts": {
    "dev": "tailwindcss -i src/css/main.css -o assets/css/theme.min.css --watch",
    "build:css": "tailwindcss -i src/css/main.css -o assets/css/theme.min.css --minify",
    "build:editor-css": "tailwindcss -i src/css/editor.css -o assets/css/editor.min.css --minify",
    "build:js": "esbuild src/js/theme.js --bundle --minify --outfile=assets/js/theme.min.js",
    "build": "npm run build:css && npm run build:editor-css && npm run build:js"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "tailwindcss": "^3.4.1"
  }
}
